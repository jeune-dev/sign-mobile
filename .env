CONTRAT_TRAVAIL_SIGNER_PATH=/v1/professionnel/contratTravail

# Quittance de loyer
QUITTANCE_CREER_PATH=/v1/professionnel/creation-quittance-loyer
QUITTANCE_LISTE_PATH=/v1/professionnel
QUITTANCE_DETAIL_PATH=/v1/professionnel
