API_BASE_URL=https://sign-backend-ha5a.onrender.com/sign

# Auth
AUTH_LOGIN_PATH=/v1/auth/login
AUTH_REGISTER_PATH=/v1/auth/register
AUTH_REFRESH_PATH=/v1/auth/refresh
AUTH_LOGOUT_PATH=/v1/auth/logout

# Account
ACCOUNT_ME_PATH=/v1/account/me
ACCOUNT_MODIFIER_INFO_PATH=/v1/account/modifier-info-personnelles
ACCOUNT_CHANGE_PASSWORD_PATH=/v1/account/change-password
ACCOUNT_FORGOT_PASSWORD_PATH=/v1/account/forgot-password
ACCOUNT_RESET_PASSWORD_PATH=/v1/account/reset-password
ACCOUNT_DEVICE_TOKEN_PATH=/v1/account/device-token

# Client
CLIENT_LISTE_PATH=/v1/professionnel/client/liste-clients
CLIENT_AJOUT_PATH=/v1/professionnel/client/ajout-client
CLIENT_RECHERCHE_PATH=/v1/professionnel/client/recherche-client

# Facture / Document
