# Particulier
PARTICULIER_DASHBOARD_STATS_PATH=/v1/particulier/dashboard/stats
PARTICULIER_FACTURES_PATH=/v1/particulier/factures
PARTICULIER_CONTRATS_PATH=/v1/particulier/contrats
