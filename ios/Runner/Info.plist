<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>SIGN</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>SIGN</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<!-- AS-05 : Portrait uniquement — l'UI n'est pas conçue pour le landscape -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- AS-06 : Force le mode clair — pas de Dark Mode géré dans cette version -->
	<key>UIUserInterfaceStyle</key>
	<string>Light</string>

	<!-- Notifications push FCM -->
	<key>NSUserNotificationsUsageDescription</key>
	<string>SIGN vous envoie des notifications pour vous informer de la signature de vos contrats et des mises à jour importantes.</string>

	<!-- ATS : HTTPS uniquement, aucun cleartext autorisé -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsArbitraryLoadsInWebContent</key>
		<false/>
	</dict>

	<!-- BLK-03/AS-02 : Permissions galerie et caméra — obligatoires pour image_picker -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>SIGN utilise votre bibliothèque photo pour ajouter une photo de profil et un logo d'entreprise.</string>
	<key>NSCameraUsageDescription</key>
	<string>SIGN peut utiliser l'appareil photo pour prendre une photo de profil.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>SIGN enregistre vos documents signés dans votre bibliothèque photo.</string>
</dict>
</plist>
