<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31) system splash screen.
         Aucun logo affiché au démarrage : fond blanc + icône transparente.
         L'utilisateur ne voit qu'un écran blanc avant l'animation d'onboarding. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_blank</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
