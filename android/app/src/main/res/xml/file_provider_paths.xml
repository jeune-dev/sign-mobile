<?xml version="1.0" encoding="utf-8"?>
<!-- VULN-M04 : Chemins restreints aux seuls répertoires nécessaires -->
<paths>
    <!-- Cache interne uniquement (PDFs temporaires) -->
    <cache-path name="cache" path="pdfs/" />
    <!-- Fichiers internes de l'app -->
    <files-path name="files" path="downloads/" />
    <!-- Cache externe (partage de fichiers téléchargés) -->
    <external-cache-path name="external_cache" path="pdfs/" />
</paths>
